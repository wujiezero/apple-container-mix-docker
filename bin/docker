EMPTY_SPEC = {"bool": {}, "value": {}}


# ---------------------------------------------------------------------------
# handlers

def run_generic(target, spec, name, rest, drop_positionals=False):
    flags, pos, frozen = translate(rest, spec, name)
    if drop_positionals and (pos or frozen):
        warn(f"'{name}' does not accept name filters on Apple container; "
             f"ignoring {pos + frozen}")
        pos, frozen = [], []
    execute([CONTAINER_BIN, *GLOBAL_FLAGS, *target, *flags, *pos, *frozen])


def host_platform():
    import platform as _platform
    mach = _platform.machine().lower()
    arch = {"arm64": "arm64", "aarch64": "arm64",
            "x86_64": "amd64", "amd64": "amd64"}.get(mach)
    return f"linux/{arch}" if arch else None


def cmd_pull(rest):
    flags, pos, frozen = translate(rest, PULL_SPEC, "pull")
    # Docker pulls only the host platform by default; Apple container pulls
    # every architecture in the manifest. Limit to the host platform unless
    # the user chose one (flag or CONTAINER_DEFAULT_PLATFORM) or opted out
    # with DOCKER_SHIM_PULL_ALL_PLATFORMS=1.
    if ("--platform" not in flags and "--help" not in flags
            and not os.environ.get("CONTAINER_DEFAULT_PLATFORM")
            and os.environ.get("DOCKER_SHIM_PULL_ALL_PLATFORMS", "") in ("", "0")):
        plat = host_platform()
        if plat:
            flags += ["--platform", plat]
    execute([CONTAINER_BIN, *GLOBAL_FLAGS, "image", "pull", *flags, *pos, *frozen])


def cmd_restart(rest):
    flags, pos, frozen = translate(rest, STOP_SPEC, "restart")
    ids = pos + frozen
    if not ids:
        die("'restart' requires at least one container")
    # Emulated: Apple container has no restart. Stop (ignore failures for
    # already-stopped containers), then start each one.
    run_sub([CONTAINER_BIN, *GLOBAL_FLAGS, "stop", *flags, *ids])
    rc = 0
    for cid in ids:
        rc = run_sub([CONTAINER_BIN, *GLOBAL_FLAGS, "start", cid]) or rc
    sys.exit(rc)


def cmd_inspect(rest):
    kinds = ["container", "image"]
    ids = []
    i = 0
    while i < len(rest):
        tok = rest[i]
        if tok in ("-f", "--format") or tok.startswith("--format="):
            if "=" not in tok:
                i += 1
            warn("'inspect --format' templates are not supported; printing full JSON")
        elif tok in ("--type",) or tok.startswith("--type="):
            val = tok.partition("=")[2]
            if not val:
                i += 1
                val = rest[i] if i < len(rest) else ""
            if val in ("container", "image"):
                kinds = [val]
        elif tok in ("-s", "--size"):
            pass
        elif tok in ("-h", "--help"):
            execute([CONTAINER_BIN, "inspect", "--help"])
        elif tok.startswith("-"):
            warn(f"unknown option {tok} for 'inspect'; dropping it")
        else:
            ids.append(tok)
        i += 1
    if not ids:
        die("'inspect' requires at least one container or image")
    last = None
    for kind in kinds:
        argv = [CONTAINER_BIN, *GLOBAL_FLAGS]
        argv += ["inspect"] if kind == "container" else ["image", "inspect"]
        if DEBUG:
            print(f"docker-shim: try: {shlex.join(argv + ids)}", file=sys.stderr)
        last = subprocess.run(argv + ids, capture_output=True, text=True)
        if last.returncode == 0:
            sys.stdout.write(last.stdout)
            sys.exit(0)
    sys.stderr.write(last.stderr)
    sys.exit(last.returncode)


def cmd_login(rest):
    user = password = server = None
    pw_stdin = False
    i = 0
    while i < len(rest):
        tok = rest[i]
        name, eq, val = tok.partition("=")
        if name in ("-u", "--username"):
            if not eq:
                i += 1
                val = rest[i] if i < len(rest) else die("--username requires a value")
            user = val
        elif name in ("-p", "--password"):
            if not eq:
                i += 1
                val = rest[i] if i < len(rest) else die("--password requires a value")
            password = val
        elif tok == "--password-stdin":
            pw_stdin = True
        elif tok in ("-h", "--help"):
            execute([CONTAINER_BIN, "registry", "login", "--help"])
        elif tok.startswith("-"):
            warn(f"unknown option {tok} for 'login'; dropping it")
        else:
            server = tok
        i += 1
    argv = [CONTAINER_BIN, *GLOBAL_FLAGS, "registry", "login"]
    if user:
        argv += ["--username", user]
    if password is not None or pw_stdin:
        argv.append("--password-stdin")
    argv.append(server or "docker.io")
    if password is not None:
        sys.exit(run_sub(argv, input=password.encode()))
    execute(argv)


def cmd_logout(rest):
    server = next((t for t in rest if not t.startswith("-")), "docker.io")
    execute([CONTAINER_BIN, *GLOBAL_FLAGS, "registry", "logout", server])


def confirm_prune(rest, what):
    forced = any(t in ("-f", "--force") for t in rest)
    if not forced and sys.stdin.isatty():
        try:
            answer = input(f"WARNING! This will remove {what}.\nAre you sure? [y/N] ")
        except EOFError:
            answer = ""
        if answer.strip().lower() not in ("y", "yes"):
            sys.exit(0)


def cmd_system_prune(rest):
    confirm_prune(rest, "all stopped containers, unused images and unused networks")
    remove_all = any(t in ("-a", "--all") for t in rest)
    steps = [["prune"], ["image", "prune"] + (["--all"] if remove_all else []),
             ["network", "prune"]]
    if "--volumes" in rest:
        steps.append(["volume", "prune"])
    rc = 0
    for step in steps:
        rc = run_sub([CONTAINER_BIN, *GLOBAL_FLAGS, *step]) or rc
    sys.exit(rc)


def cmd_container_prune(rest):
    confirm_prune(rest, "all stopped containers")
    execute([CONTAINER_BIN, *GLOBAL_FLAGS, "prune"])


def cmd_image_prune(rest):
    confirm_prune(rest, "unused images")
    argv = [CONTAINER_BIN, *GLOBAL_FLAGS, "image", "prune"]
    if any(t in ("-a", "--all") for t in rest):
        argv.append("--all")
    execute(argv)


def cmd_network_prune(rest):
    confirm_prune(rest, "unused networks")
    execute([CONTAINER_BIN, *GLOBAL_FLAGS, "network", "prune"])


def cmd_volume_prune(rest):
    confirm_prune(rest, "unused volumes")
    execute([CONTAINER_BIN, *GLOBAL_FLAGS, "volume", "prune"])


def cmd_version(_rest):
    print(f"Docker compatibility shim for Apple container (docker-shim {SHIM_VERSION})")
    sys.stdout.flush()
    execute([CONTAINER_BIN, "--version"])


def cmd_unsupported(name, hint=""):
    def h(_rest):
        msg = f"'docker {name}' has no Apple container equivalent"
        if hint:
            msg += f"; {hint}"
        die(msg)
    return h


HELP_TEXT = f"""docker-shim {SHIM_VERSION} — Docker CLI compatibility layer for Apple container

Usage: docker COMMAND [ARGS...]

Translated commands:
  run, create, exec, ps, start, stop, restart*, kill, rm, logs, cp, stats,
  inspect, export, pull, push, images, rmi, tag, save, load, build,
  login, logout, version, info
  image / container / volume / network / system subcommand groups

* restart is emulated as stop + start.

Everything is forwarded to the `container` CLI (apple/container).
Unsupported docker flags are dropped with a warning (DOCKER_SHIM_STRICT=1 to fail).
DOCKER_SHIM_DEBUG=1 prints each translated command.

Run 'container --help' to see the native CLI.
"""


def print_help():
    print(HELP_TEXT)
    sys.exit(0)


# ---------------------------------------------------------------------------
# dispatch

HANDLERS = {
    "run":     lambda r: run_generic(["run"], RUN_SPEC, "run", r),
    "create":  lambda r: run_generic(["create"], RUN_SPEC, "create", r),
    "exec":    lambda r: run_generic(["exec"], EXEC_SPEC, "exec", r),
    "ps":      lambda r: run_generic(["list"], PS_SPEC, "ps", r, drop_positionals=True),
    "start":   lambda r: run_generic(["start"], START_SPEC, "start", r),
    "stop":    lambda r: run_generic(["stop"], STOP_SPEC, "stop", r),
    "restart": cmd_restart,
    "kill":    lambda r: run_generic(["kill"], KILL_SPEC, "kill", r),
    "rm":      lambda r: run_generic(["delete"], RM_SPEC, "rm", r),
    "logs":    lambda r: run_generic(["logs"], LOGS_SPEC, "logs", r),
    "cp":      lambda r: run_generic(["cp"], CP_SPEC, "cp", r),
    "stats":   lambda r: run_generic(["stats"], STATS_SPEC, "stats", r),
    "inspect": cmd_inspect,
    "export":  lambda r: run_generic(["export"], EXPORT_SPEC, "export", r),
    "pull":    cmd_pull,
    "push":    lambda r: run_generic(["image", "push"], PUSH_SPEC, "push", r),
    "images":  lambda r: run_generic(["image", "list"], IMAGES_SPEC, "images", r,
                                     drop_positionals=True),
    "rmi":     lambda r: run_generic(["image", "delete"], RMI_SPEC, "rmi", r),
    "tag":     lambda r: run_generic(["image", "tag"], EMPTY_SPEC, "tag", r),
    "save":    lambda r: run_generic(["image", "save"], SAVE_SPEC, "save", r),
    "load":    lambda r: run_generic(["image", "load"], LOAD_SPEC, "load", r),
    "build":   lambda r: run_generic(["build"], BUILD_SPEC, "build", r),
    "login":   cmd_login,
    "logout":  cmd_logout,
    "version": cmd_version,
    "info":    lambda r: execute([CONTAINER_BIN, *GLOBAL_FLAGS, "system", "status"]),
    # no equivalents:
    "attach":  cmd_unsupported("attach", "use 'docker logs -f <id>' or "
                               "'docker exec -it <id> sh'"),
    "commit":  cmd_unsupported("commit"),
    "diff":    cmd_unsupported("diff"),
    "events":  cmd_unsupported("events"),
    "history": cmd_unsupported("history"),
    "pause":   cmd_unsupported("pause"),
    "unpause": cmd_unsupported("unpause"),
    "port":    cmd_unsupported("port", "check 'docker inspect <id>' for port mappings"),
    "rename":  cmd_unsupported("rename"),
    "top":     cmd_unsupported("top", "use 'docker exec <id> ps aux'"),
    "update":  cmd_unsupported("update"),
    "wait":    cmd_unsupported("wait"),
    "import":  cmd_unsupported("import", "use 'docker load' for OCI archives"),
    "swarm":   cmd_unsupported("swarm"),
    "context": cmd_unsupported("context"),
    "manifest": cmd_unsupported("manifest"),
    "compose": cmd_unsupported("compose", "Apple container has no compose support; "
                               "run services individually with 'docker run'"),
}

CONTAINER_GROUP = {
    "ls": "ps", "list": "ps", "ps": "ps",
    "rm": "rm", "remove": "rm", "delete": "rm",
    "run": "run", "create": "create", "exec": "exec",
    "start": "start", "stop": "stop", "restart": "restart", "kill": "kill",
    "logs": "logs", "inspect": "inspect", "stats": "stats", "cp": "cp",
    "export": "export", "attach": "attach", "pause": "pause",
    "unpause": "unpause", "port": "port", "rename": "rename", "top": "top",
    "update": "update", "wait": "wait", "diff": "diff", "commit": "commit",
}

IMAGE_GROUP = {
    "ls": "images", "list": "images",
    "rm": "rmi", "remove": "rmi", "delete": "rmi",
    "pull": "pull", "push": "push", "tag": "tag",
    "save": "save", "load": "load", "build": "build",
    "history": "history", "import": "import",
}


def dispatch_group(group, sub, rest):
    """Handle docker's two-level management commands (image/container/...)."""
    if group == "container":
        if sub == "prune":
            return cmd_container_prune(rest)
        mapped = CONTAINER_GROUP.get(sub)
        if mapped:
            return HANDLERS[mapped](rest)
    elif group == "image":
        if sub == "prune":
            return cmd_image_prune(rest)
        if sub == "inspect":
            return run_generic(["image", "inspect"], EMPTY_SPEC, "image inspect", rest)
        mapped = IMAGE_GROUP.get(sub)
        if mapped:
            return HANDLERS[mapped](rest)
    elif group == "volume":
        if sub == "prune":
            return cmd_volume_prune(rest)
        table = {"ls": ["list"], "list": ["list"], "rm": ["delete"],
                 "remove": ["delete"], "delete": ["delete"], "inspect": ["inspect"]}
        if sub == "create":
            return run_generic(["volume", "create"], VOLUME_CREATE_SPEC,
                               "volume create", rest)
        if sub in table:
            return run_generic(["volume", *table[sub]], EMPTY_SPEC,
                               f"volume {sub}", rest)
    elif group == "network":
        if sub == "prune":
            return cmd_network_prune(rest)
        table = {"ls": ["list"], "list": ["list"], "rm": ["delete"],
                 "remove": ["delete"], "delete": ["delete"], "inspect": ["inspect"]}
        if sub == "create":
            return run_generic(["network", "create"], NETWORK_CREATE_SPEC,
                               "network create", rest)
        if sub in ("connect", "disconnect"):
            return cmd_unsupported(f"network {sub}")(rest)
        if sub in table:
            return run_generic(["network", *table[sub]], EMPTY_SPEC,
                               f"network {sub}", rest)
    elif group == "system":
        if sub == "prune":
            return cmd_system_prune(rest)
        if sub == "df":
            return execute([CONTAINER_BIN, *GLOBAL_FLAGS, "system", "df"])
        if sub == "info":
            return execute([CONTAINER_BIN, *GLOBAL_FLAGS, "system", "status"])
        if sub == "events":
            return cmd_unsupported("system events")(rest)
        # start/stop/status/logs/... pass straight through — handy extras
        return execute([CONTAINER_BIN, *GLOBAL_FLAGS, "system", sub, *rest])
    elif group == "builder":
        if sub == "prune":
            return cmd_unsupported("builder prune",
                                   "use 'container builder delete' to reset the builder")(rest)
        return execute([CONTAINER_BIN, *GLOBAL_FLAGS, "builder", sub, *rest])
    elif group == "buildx":
        if sub == "build":
            return HANDLERS["build"](rest)
        return cmd_unsupported(f"buildx {sub}")(rest)
    die(f"unknown command 'docker {group} {sub}'")


GROUPS = ("container", "image", "volume", "network", "system", "builder", "buildx")

# docker global value-taking options we drop (with their values)
GLOBAL_VALUE_OPTS = ("-H", "--host", "--context", "-c", "--config",
                     "-l", "--log-level", "--tlscacert", "--tlscert", "--tlskey")


def main(argv):
    args = list(argv[1:])

    while args:
        tok = args[0]
        name = tok.partition("=")[0]
        if tok in ("-D", "--debug"):
            GLOBAL_FLAGS.append("--debug")
            args.pop(0)
        elif tok in ("-v", "--version"):
            cmd_version([])
        elif tok in ("-h", "--help"):
            print_help()
        elif name in GLOBAL_VALUE_OPTS:
            warn(f"dropping docker global option {tok}")
            args.pop(0)
            if "=" not in tok and args and not args[0].startswith("-"):
                args.pop(0)
        elif tok in ("--tls", "--tlsverify"):
            warn(f"dropping docker global option {tok}")
            args.pop(0)
        else:
            break

    if not args:
        print_help()

    cmd = args.pop(0)

    if cmd == "help":
        if args:
            cmd, args = args[0], args[1:] + ["--help"]
        else:
            print_help()

    if cmd in GROUPS:
        if not args:
            execute([CONTAINER_BIN, *GLOBAL_FLAGS,
                     "container" if cmd == "container" else cmd, "--help"]
                    if cmd != "container" else [CONTAINER_BIN, "--help"])
        sub = args.pop(0)
        dispatch_group(cmd, sub, args)
    elif cmd in HANDLERS:
        HANDLERS[cmd](args)
    else:
        die(f"unknown command 'docker {cmd}' (run 'docker --help' for the "
            "supported command list)")


if __name__ == "__main__":
    main(sys.argv)
