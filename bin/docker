#!/usr/bin/env python3
"""
docker-shim: translate Docker CLI invocations into Apple `container` CLI calls.

Targets apple/container 1.0.0 (https://github.com/apple/container).

Environment variables:
  DOCKER_SHIM_DEBUG=1          print the translated command before running it
  DOCKER_SHIM_STRICT=1         fail on unsupported flags instead of dropping them
  DOCKER_SHIM_CONTAINER_BIN    path to the `container` binary (default: container)
"""

import os
import shlex
import subprocess
import sys

SHIM_VERSION = "0.2.0"
CONTAINER_BIN = os.environ.get("DOCKER_SHIM_CONTAINER_BIN", "container")
DEBUG = os.environ.get("DOCKER_SHIM_DEBUG", "") not in ("", "0")
STRICT = os.environ.get("DOCKER_SHIM_STRICT", "") not in ("", "0")

# Sentinels for flag translation targets.
DROP = "!drop"      # unsupported: warn (or fail in strict mode) and discard
SILENT = "!silent"  # meaningless here but harmless: discard quietly

GLOBAL_FLAGS = []   # e.g. --debug, inserted right after the container binary


def warn(msg):
    print(f"docker-shim: warning: {msg}", file=sys.stderr)


def die(msg, code=1):
    print(f"docker-shim: error: {msg}", file=sys.stderr)
    sys.exit(code)


def execute(argv):
    """Replace this process with the container CLI (keeps TTY/signals/exit code)."""
    if DEBUG:
        print(f"docker-shim: exec: {shlex.join(argv)}", file=sys.stderr)
    try:
        os.execvp(argv[0], argv)
    except FileNotFoundError:
        die(f"'{argv[0]}' not found — is Apple container installed? "
            "(https://github.com/apple/container)")


def run_sub(argv, **kwargs):
    """Run a container CLI call as a subprocess (for multi-step emulations)."""
    if DEBUG:
        print(f"docker-shim: run: {shlex.join(argv)}", file=sys.stderr)
    try:
        return subprocess.run(argv, **kwargs).returncode
    except FileNotFoundError:
        die(f"'{argv[0]}' not found — is Apple container installed?")


def emit(target):
    return target if isinstance(target, list) else [target]


def handle_target(name, cmd_name, target, out_flags, value=None):
    """Append the translated flag (and value) to out_flags per its target."""
    if target == DROP:
        detail = f" (value {value!r})" if value is not None else ""
        msg = f"'{cmd_name}' does not support {name}{detail} on Apple container; dropping it"
        if STRICT:
            die(msg)
        warn(msg)
    elif target == SILENT:
        pass
    elif callable(target):
        out_flags.extend(target(value))
    elif value is not None:
        out_flags.extend(emit(target) + [value])
    else:
        out_flags.extend(emit(target))


def translate(args, spec, cmd_name):
    """Split docker-style args into (translated_flags, positionals, frozen_tail).

    spec = {"bool": {...}, "value": {...}, "stop_after": N}
    After `stop_after` positionals, remaining args are frozen verbatim
    (docker semantics: flags after the image/container go to the process).
    """
    boolmap = spec.get("bool", {})
    valmap = spec.get("value", {})
    stop_after = spec.get("stop_after")
    out_flags, positionals, frozen = [], [], []

    i = 0
    while i < len(args):
        tok = args[i]
        if stop_after is not None and len(positionals) >= stop_after:
            frozen = args[i:]
            break
        if tok == "--":
            frozen = args[i + 1:]
            break
        if tok in ("-h", "--help") and "-h" not in valmap:
            out_flags.append("--help")
        elif tok.startswith("--"):
            name, eq, val = tok.partition("=")
            if name in boolmap:
                if eq:
                    die(f"option {name} does not take a value")
                handle_target(name, cmd_name, boolmap[name], out_flags)
            elif name in valmap:
                if not eq:
                    i += 1
                    if i >= len(args):
                        die(f"option {name} requires a value")
                    val = args[i]
                handle_target(name, cmd_name, valmap[name], out_flags, val)
            else:
                unknown_flag(name, cmd_name, eq == "=")
        elif tok.startswith("-") and tok != "-":
            # short flag cluster, e.g. -itd, -p8080:80
            j = 1
            while j < len(tok):
                f = "-" + tok[j]
                if f in boolmap:
                    handle_target(f, cmd_name, boolmap[f], out_flags)
                    j += 1
                elif f in valmap:
                    rest = tok[j + 1:]
                    if rest:
                        val = rest
                    else:
                        i += 1
                        if i >= len(args):
                            die(f"option {f} requires a value")
                        val = args[i]
                    handle_target(f, cmd_name, valmap[f], out_flags, val)
                    break
                else:
                    unknown_flag(f, cmd_name, False)
                    j += 1
        else:
            positionals.append(tok)
        i += 1
    return out_flags, positionals, frozen


def unknown_flag(name, cmd_name, had_inline_value):
    msg = f"unknown option {name} for '{cmd_name}'; dropping it"
    if STRICT:
        die(msg)
    warn(msg + ("" if had_inline_value else
                " (if it takes a separate value, that value may be misparsed)"))


# ---------------------------------------------------------------------------
# value-flag callables

def fmt_json(val):
    if val.strip() in ("json", "{{json .}}"):
        return ["--format", "json"]
    warn("Go-template --format values are not supported; using default table output")
    return []


def map_network(val):
    base = val.split(",")[0]
    if base == "bridge":
        return ["--network", "default"]
    if base in ("host", "none"):
        warn(f"network mode '{base}' is not supported by Apple container; "
             "using the default network")
        return []
    return ["--network", val]


def quiet_progress(_val=None):
    return ["--progress", "none"]


